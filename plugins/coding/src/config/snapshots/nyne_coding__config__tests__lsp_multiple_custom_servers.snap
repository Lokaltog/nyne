---
source: plugins/coding/src/config/tests.rs
expression: config.lsp.custom
---
[
    CustomLspServer {
        name: "ruff",
        command: "ruff",
        args: [
            "server",
        ],
        extensions: [
            "py",
        ],
    },
    CustomLspServer {
        name: "deno",
        command: "deno",
        args: [
            "lsp",
        ],
        extensions: [
            "ts",
            "tsx",
        ],
    },
]

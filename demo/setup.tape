Require nyne

Require bat
Require eza
Require glow
Require yazi

Set Shell "bash"
Set FontSize 16
Set FontFamily "Iosevka-Classic"
Set Width 1600
Set Height 800
Set Padding 10
Set Theme "Catppuccin Mocha"
Set BorderRadius 0
Set TypingSpeed 20ms
Set CursorBlink false
Set Framerate 60
Set PlaybackSpeed 1

Env BAT_PAGER ''

Hide
Type "nyne attach -- bash"
Enter
